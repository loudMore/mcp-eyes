{
  "mcpServers": {
    "vision-extension": {
      "command": "python",
      "args": ["-m", "vision_extension"],
      "env": {
        "VISION_EXTENSION_PROTOCOL": "openai",
        "VISION_EXTENSION_BASE_URL": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "VISION_EXTENSION_API_KEY": "REPLACE_WITH_YOUR_KEY",
        "VISION_EXTENSION_MODEL": "doubao-seed-2.0-pro",
        "VISION_EXTENSION_LANG": "auto",
        "VISION_EXTENSION_MAX_IMAGE_DIM": "2048",
        "VISION_EXTENSION_CACHE_ENABLED": "true"
      }
    }
  }
}
