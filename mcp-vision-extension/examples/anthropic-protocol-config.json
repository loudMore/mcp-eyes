{
  "mcpServers": {
    "vision-extension": {
      "command": "python",
      "args": ["-m", "vision_extension"],
      "env": {
        "VISION_EXTENSION_PROTOCOL": "anthropic",
        "VISION_EXTENSION_BASE_URL": "https://ark.cn-beijing.volces.com/api/coding",
        "VISION_EXTENSION_API_KEY": "REPLACE_WITH_YOUR_KEY",
        "VISION_EXTENSION_MODEL": "doubao-seed-1-6-vision",
        "VISION_EXTENSION_ANTHROPIC_VERSION": "2023-06-01"
      }
    }
  }
}
