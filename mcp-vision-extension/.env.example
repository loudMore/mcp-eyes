# --- Required ---
# openai | anthropic
MCP_EYES_PROTOCOL=openai

# Endpoint base URL (no trailing slash, no /chat/completions or /messages suffix)
MCP_EYES_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# API key
MCP_EYES_API_KEY=ark-xxxxxxxx

# Vision model identifier
MCP_EYES_MODEL=doubao-seed-2.0-pro

# --- Optional ---
# auto detects from question text; force with en or zh
MCP_EYES_LANG=auto

# Auto-resize longest edge to this many pixels (requires Pillow). 0 = no resize.
MCP_EYES_MAX_IMAGE_DIM=2048

MCP_EYES_MAX_TOKENS=1536
MCP_EYES_TEMPERATURE=0.2
MCP_EYES_TIMEOUT=90

# Disk cache: same image + same prompt + same model = cached
MCP_EYES_CACHE_ENABLED=true
# Default: ~/.cache/mcp-eyes
# MCP_EYES_CACHE_DIR=

# Anthropic-only
# MCP_EYES_ANTHROPIC_VERSION=2023-06-01
